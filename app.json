{
  "expo": {
    "name": "TAWTIK",
    "slug": "tawtik",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon-square.png",
    "scheme": "tawtik",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon-square.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a3050"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tawtik.notaires",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-square.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f84ef941-8acc-42da-ac13-8ba5e8b9b096"
      }
    }
  }
}
